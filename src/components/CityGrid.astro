---
// src/components/CityGrid.astro
import { GEORGIA_CITIES } from '../lib/weather';
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h2 class="font-display text-3xl font-bold text-white mb-2 text-center">Погода по городам Грузии</h2>
  <p class="text-white/60 text-center mb-10">Выберите город для подробного прогноза</p>

  <div class="mb-8">
    <h3 class="text-white/70 text-sm uppercase tracking-wider mb-4 font-semibold">🏙 Города</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {GEORGIA_CITIES.filter(c => !c.isResort).map(city => (
        <a
          href={`/pagoda-${city.slug}`}
          class="group backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl p-4 hover:bg-white/20 hover:border-white/40 hover:scale-105 transition-all duration-200 text-center"
        >
          <div class="text-2xl mb-2">🌆</div>
          <p class="text-white font-semibold text-sm">{city.nameRu}</p>
          <p class="text-white/40 text-xs mt-0.5">{city.description}</p>
        </a>
      ))}
    </div>
  </div>

  <div>
    <h3 class="text-white/70 text-sm uppercase tracking-wider mb-4 font-semibold">🏔 Курорты</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {GEORGIA_CITIES.filter(c => c.isResort).map(city => (
        <a
          href={`/pagoda-${city.slug}`}
          class="group backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl p-4 hover:bg-white/20 hover:border-white/40 hover:scale-105 transition-all duration-200 text-center"
        >
          <div class="text-2xl mb-2">🏖</div>
          <p class="text-white font-semibold text-sm">{city.nameRu}</p>
          <p class="text-white/40 text-xs mt-0.5">{city.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
