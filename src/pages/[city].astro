---
// src/pages/[city].astro
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import WeatherCard from '../components/WeatherCard.astro';
import FAQ from '../components/FAQ.astro';
import { GEORGIA_CITIES, fetchWeatherByCoords, getCityBySlug } from '../lib/weather';
import { getCitySeo } from '../lib/seo';

const { city: cityParam } = Astro.params;

// Extract slug from URL pattern "pagoda-{slug}"
const slug = cityParam?.startsWith('pagoda-') ? cityParam.replace('pagoda-', '') : null;

if (!slug) {
  return Astro.redirect('/');
}

const cityInfo = getCityBySlug(slug);
if (!cityInfo) {
  return Astro.redirect('/');
}

const seo = getCitySeo(cityInfo.slug, cityInfo.nameRu, cityInfo.description);

let weatherData = null;
let error = null;

try {
  weatherData = await fetchWeatherByCoords(cityInfo.lat, cityInfo.lon, cityInfo.nameRu, cityInfo.nameEn);
} catch (e) {
  error = (e as Error).message;
}

// Breadcrumb schema
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Пагода Грузия", "item": "https://pagoda.ge" },
    { "@type": "ListItem", "position": 2, "name": `Пагода ${cityInfo.nameRu}`, "item": seo.canonical }
  ]
};
---

<BaseLayout seo={seo} isDay={weatherData?.current.isDay ?? true}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />

  <!-- City Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-white/50 text-sm mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-white transition-colors">Пагода</a>
      <span>/</span>
      <span class="text-white">{cityInfo.nameRu}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Left: weather -->
      <div class="flex-1 min-w-0">
        <div class="mb-6">
          <div class="inline-flex items-center gap-2 backdrop-blur-md bg-white/15 border border-white/25 rounded-full px-4 py-1.5 mb-4">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-white/70 text-xs">Обновлено сейчас</span>
          </div>
          <h1 class="font-display text-4xl sm:text-5xl font-black text-white mb-2">
            Пагода {cityInfo.nameRu}
          </h1>
          <p class="text-white/60 text-lg">{cityInfo.description} · Грузия</p>
        </div>

        {error ? (
          <div class="backdrop-blur-md bg-red-500/20 border border-red-400/30 rounded-2xl p-6">
            <p class="text-white font-semibold mb-2">⚠️ Ошибка загрузки данных</p>
            <p class="text-white/60 text-sm">{error}</p>
          </div>
        ) : weatherData ? (
          <WeatherCard data={weatherData} />
        ) : null}
      </div>

      <!-- Right: city info -->
      <div class="lg:w-80 space-y-4">
        <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl p-6">
          <h2 class="font-display text-xl font-bold text-white mb-4">О городе</h2>
          <p class="text-white/70 text-sm leading-relaxed">
            {cityInfo.nameRu} — {cityInfo.description} в Грузии.
            {cityInfo.isResort ? ' Популярный туристический курорт.' : ' Один из важных городов страны.'}
          </p>
          <div class="mt-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-white/50">Координаты</span>
              <span class="text-white font-mono text-xs">{cityInfo.lat.toFixed(3)}, {cityInfo.lon.toFixed(3)}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-white/50">Тип</span>
              <span class="text-white">{cityInfo.isResort ? 'Курорт' : 'Город'}</span>
            </div>
          </div>
        </div>

        <!-- Other cities -->
        <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl p-6">
          <h3 class="text-white font-semibold text-sm mb-4 uppercase tracking-wider">Другие города</h3>
          <div class="space-y-1">
            {GEORGIA_CITIES.filter(c => c.slug !== cityInfo.slug).slice(0, 8).map(c => (
              <a
                href={`/pagoda-${c.slug}`}
                class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-white/10 transition-colors group"
              >
                <span class="text-white/70 group-hover:text-white text-sm transition-colors">{c.nameRu}</span>
                <svg class="w-4 h-4 text-white/30 group-hover:text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Text -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-3xl p-8">
      <h2 class="font-display text-2xl font-bold text-white mb-4">
        Погода в {cityInfo.nameRu} — Пагода {cityInfo.nameRu}
      </h2>
      <div class="text-white/70 space-y-3 text-sm leading-relaxed">
        <p>
          На странице <strong class="text-white">Пагода {cityInfo.nameRu}</strong> вы найдёте актуальный прогноз погоды на сегодня, на 7 дней и на 30 дней.
          {cityInfo.nameRu} — это {cityInfo.description} {cityInfo.isResort ? ', куда ежегодно приезжают тысячи туристов.' : ' Грузии.'}
        </p>
        <p>
          Наш сервис предоставляет данные в реальном времени: температуру воздуха, ощущаемую температуру, влажность, скорость и направление ветра, атмосферное давление и видимость.
          Прогноз обновляется каждые 10 минут.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ cityNameRu={cityInfo.nameRu} />
</BaseLayout>
