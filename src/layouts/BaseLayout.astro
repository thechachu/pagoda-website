---
// src/layouts/BaseLayout.astro
import type { SeoData } from '../lib/seo';

interface Props {
  seo: SeoData;
  isDay?: boolean;
}

const { seo, isDay = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  <meta name="keywords" content={seo.keywords} />
  <link rel="canonical" href={seo.canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={seo.title} />
  <meta property="og:description" content={seo.description} />
  <meta property="og:url" content={seo.canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://pagoda.ge/og-image.png" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:site_name" content="Пагода Грузия" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.title} />
  <meta name="twitter:description" content={seo.description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Nunito:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Пагода Грузия",
    "url": "https://pagoda.ge",
    "description": seo.description,
    "inLanguage": "ru",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://pagoda.ge/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
</head>
<body class={`font-body min-h-screen transition-colors duration-1000 ${isDay ? 'bg-gradient-to-br from-sky-300 via-blue-500 to-blue-800' : 'bg-gradient-to-br from-indigo-950 via-blue-950 to-slate-900'}`}>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/10 border-b border-white/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center group-hover:bg-white/30 transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.9"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-display text-xl font-bold text-white">Пагода</span>
          <span class="text-white/60 text-sm font-body">Грузия</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-white/80 hover:text-white text-sm font-medium transition-colors">Главная</a>
          <div class="relative group">
            <button class="text-white/80 hover:text-white text-sm font-medium transition-colors flex items-center gap-1">
              Города
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute top-full left-0 mt-2 w-64 backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl p-3 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 grid grid-cols-2 gap-1">
              <a href="/pagoda-tbilisi" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Тбилиси</a>
              <a href="/pagoda-batumi" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Батуми</a>
              <a href="/pagoda-kutaisi" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Кутаиси</a>
              <a href="/pagoda-gudauri" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Гудаури</a>
              <a href="/pagoda-mestia" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Местиа</a>
              <a href="/pagoda-borjomi" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Боржоми</a>
              <a href="/pagoda-bakuriani" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Бакуриани</a>
              <a href="/pagoda-sighnaghi" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Сигнахи</a>
              <a href="/pagoda-kobuleti" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Кобулети</a>
              <a href="/pagoda-ureki" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 text-xs transition-colors">Уреки</a>
            </div>
          </div>
          <a href="/blog" class="text-white/80 hover:text-white text-sm font-medium transition-colors">Блог</a>
        </div>

        <!-- Mobile menu toggle -->
        <button id="mobile-menu-btn" class="md:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/20 backdrop-blur-xl bg-white/10">
      <div class="px-4 py-4 space-y-2">
        <a href="/" class="block text-white/80 hover:text-white py-2 text-sm font-medium">Главная</a>
        <div class="border-t border-white/10 pt-2">
          <p class="text-white/40 text-xs mb-2 uppercase tracking-wider">Города</p>
          <div class="grid grid-cols-2 gap-1">
            <a href="/pagoda-tbilisi" class="text-white/70 hover:text-white py-1.5 text-sm">Тбилиси</a>
            <a href="/pagoda-batumi" class="text-white/70 hover:text-white py-1.5 text-sm">Батуми</a>
            <a href="/pagoda-kutaisi" class="text-white/70 hover:text-white py-1.5 text-sm">Кутаиси</a>
            <a href="/pagoda-gudauri" class="text-white/70 hover:text-white py-1.5 text-sm">Гудаури</a>
            <a href="/pagoda-mestia" class="text-white/70 hover:text-white py-1.5 text-sm">Местиа</a>
            <a href="/pagoda-borjomi" class="text-white/70 hover:text-white py-1.5 text-sm">Боржоми</a>
            <a href="/pagoda-bakuriani" class="text-white/70 hover:text-white py-1.5 text-sm">Бакуриани</a>
            <a href="/pagoda-sighnaghi" class="text-white/70 hover:text-white py-1.5 text-sm">Сигнахи</a>
            <a href="/pagoda-kobuleti" class="text-white/70 hover:text-white py-1.5 text-sm">Кобулети</a>
            <a href="/pagoda-ureki" class="text-white/70 hover:text-white py-1.5 text-sm">Уреки</a>
          </div>
        </div>
        <a href="/blog" class="block text-white/80 hover:text-white py-2 text-sm font-medium border-t border-white/10 pt-3">Блог</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-20 backdrop-blur-md bg-black/20 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="col-span-1 md:col-span-2">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.9"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <span class="font-display text-xl font-bold text-white">Пагода Грузия</span>
          </div>
          <p class="text-white/50 text-sm leading-relaxed max-w-sm">Точный прогноз погоды для всех городов и курортов Грузии. Данные обновляются каждые 10 минут.</p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Города</h4>
          <ul class="space-y-2">
            <li><a href="/pagoda-tbilisi" class="text-white/50 hover:text-white text-sm transition-colors">Тбилиси</a></li>
            <li><a href="/pagoda-batumi" class="text-white/50 hover:text-white text-sm transition-colors">Батуми</a></li>
            <li><a href="/pagoda-kutaisi" class="text-white/50 hover:text-white text-sm transition-colors">Кутаиси</a></li>
            <li><a href="/pagoda-gudauri" class="text-white/50 hover:text-white text-sm transition-colors">Гудаури</a></li>
            <li><a href="/pagoda-mestia" class="text-white/50 hover:text-white text-sm transition-colors">Местиа</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Курорты</h4>
          <ul class="space-y-2">
            <li><a href="/pagoda-borjomi" class="text-white/50 hover:text-white text-sm transition-colors">Боржоми</a></li>
            <li><a href="/pagoda-bakuriani" class="text-white/50 hover:text-white text-sm transition-colors">Бакуриани</a></li>
            <li><a href="/pagoda-sighnaghi" class="text-white/50 hover:text-white text-sm transition-colors">Сигнахи</a></li>
            <li><a href="/pagoda-ureki" class="text-white/50 hover:text-white text-sm transition-colors">Уреки</a></li>
            <li><a href="/blog" class="text-white/50 hover:text-white text-sm transition-colors">Блог</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-white/30 text-xs">© 2025 pagoda.ge — Пагода Грузия. Все права защищены.</p>
        <p class="text-white/30 text-xs">Данные: OpenWeatherMap</p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>
</body>
</html>
